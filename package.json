{
  "name": "ecoagent",
  "version": "2.0.0",
  "description": "EcoAgent — Stochastic Climate Risk Platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grammyjs/files": "^1.2.0",
    "@supabase/supabase-js": "^2.49.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.0.0",
    "elevenlabs": "^1.59.0",
    "grammy": "^1.32.0",
    "openai": "^4.73.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
